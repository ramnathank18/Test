  ON SOL.X_LOCAL_CURRENCY_CODE = W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATETOCURRENCY
      AND  SOL.DOC_CURR_CODE = W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATEFROMCURRENCY
AND	SOL.EXCHANGE_DT >= W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATECREATIONDATE
AND	SOL.EXCHANGE_DT < W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATELASTUPDATEDATE
AND	COALESCE(SOL.LOC_EXCH_RATE_TYPE,'#BIAPPS.DEFAULT_LOC_RATE_TYPE') = W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATECONVERSIONTYPE
  AND W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATETOCURRENCY = 'USD'
  AND W_EXCH_RATE_G_CNVRSN_MXN_USD.DAILYRATECONVERSIONTYPE = 'Corporate'
    LEFT OUTER JOIN  (
select 	
	GL_DAILY_RATES.DAILYRATECONVERSIONRATE AS GLBL2_EXCH_RATE,GL_DAILY_RATES.DAILYRATECONVERSIONRATE AS GLBL1_EXCH_RATE,
    to_date(GL_DAILY_RATES.DAILYRATECONVERSIONDATE)   AS EXCH_DATE,	GL_DAILY_RATES.DAILYRATEFROMCURRENCY AS W_FROM_CURRENCY_CODE,	
	GL_DAILY_RATES.DAILYRATECONVERSIONRATE AS GLBL3_EXCH_RATE,GL_DAILY_RATES.DAILYRATETOCURRENCY as W_TO_CURRENCY_CODE
	,GL_DAILY_RATES.DAILYRATECONVERSIONTYPE
from	NBLBI_FUSION_FIN_COMMON.GL_DAILY_RATES  GL_DAILY_RATES
)  GL_DAILY_RATES  
    ON  SOL.DOC_CURR_CODE  = GL_DAILY_RATES.W_FROM_CURRENCY_CODE
	AND to_date(SOL.EXCHANGE_DT) = GL_DAILY_RATES.EXCH_DATE
	 AND GL_DAILY_RATES.W_TO_CURRENCY_CODE = 'USD'
  AND GL_DAILY_RATES.DAILYRATECONVERSIONTYPE = 'Corporate'

)

