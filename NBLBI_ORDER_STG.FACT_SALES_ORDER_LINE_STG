        WHEN SOL.ROOT_PROD_LINE_ID =  CONCAT_WS('-',1,SOL.INTEGRATION_ID) THEN 'Y' 
        ELSE 'N' 
    END,
'N') AS ROOT_PROD_FLG,

-- X_ORDERED_DATE_CUST_TZ
CASE
    WHEN LENGTH(COALESCE(WC_CUST_SITE_USE_D1_SHIP_TO.TIME_ZONE_GID, '-')) <= 1
        THEN SOL.ORDERED_ON_DT
    ELSE from_utc_timestamp(to_utc_timestamp(SOL.ORDERED_ON_DT, 'PST'), WC_CUST_SITE_USE_D1_SHIP_TO.TIME_ZONE_GID)
END AS X_ORDERED_DATE_CUST_TZ,

-- X_REQUEST_DATE_CUST_TZ
SOL.X_REQUEST_DATE AS X_REQUEST_DATE_CUST_TZ,

SOL.X_REFERENCE_BOL_NUMBER as  X_REFERENCE_BOL_NUMBER,
--143736 changed for RMA details
CASE
    WHEN SOL.X_REFERENCE_LINE_ID IS NULL THEN NULL
    ELSE (CASE 
    WHEN SOL.X_OOL_LINE_NUMBER IS NULL 
         AND SOL.X_OOL_SHIPMENT_NUMBER IS NULL 
        THEN '-'
    ELSE 
    -- CONCAT(CAST(SOL.X_OOL_LINE_NUMBER AS STRING), '.', CAST(SOL.X_OOL_SHIPMENT_NUMBER AS STRING))
    CAST(SOL.X_OOL_LINE_NUMBER AS STRING)
END) 
END AS X_REFERENCE_ORDER_LINE,

CASE
    WHEN SOL.X_REFERENCE_LINE_ID is NULL THEN NULL
    ELSE SOL.X_REFERENCE_LINE_ID
END AS X_REFERENCE_ORDER_LINE_ID,
cast(GL_DAILY_RATES.GLBL1_EXCH_RATE as double) GLOBAL1_EXCHANGE_RATE,
cast(GL_DAILY_RATES.GLBL2_EXCH_RATE  as double) GLOBAL2_EXCHANGE_RATE,
cast(GL_DAILY_RATES.GLBL3_EXCH_RATE   as double) GLOBAL3_EXCHANGE_RATE

