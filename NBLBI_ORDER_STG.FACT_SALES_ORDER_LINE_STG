LEFT JOIN (
  SELECT 
    DOO_LINES_ALL.LINEID AS LINE_ID,
    MAX(DOO_HOLD_INSTANCES.HOLDINSTANCELASTUPDATEDATE) AS HOLD_LAST_UPDATE_DATE,
    MAX(DOO_HOLD_CODES.HOLDLASTUPDATEDATE) AS HOLD_DEFN_LAST_UPDATE_DATE
  FROM NBLBI_FUSION_ONT.DOO_LINES_ALL DOO_LINES_ALL
 LEFT JOIN NBLBI_FUSION_ONT.DOO_HOLD_INSTANCES DOO_HOLD_INSTANCES
    ON DOO_LINES_ALL.LINEHEADERID = DOO_HOLD_INSTANCES.HOLDINSTANCETRANSACTIONENTITYID1
  LEFT JOIN NBLBI_FUSION_ONT.DOO_HOLD_CODES DOO_HOLD_CODES
