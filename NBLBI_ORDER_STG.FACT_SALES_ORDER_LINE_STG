    SELECT 
        SITEUSEID SITE_USE_ID,
        CUSTACCTSITEID CUSTOMER_SHIP_TO_LOC_ID,
        CUSTACCOUNTID CUST_ACCNT_ID,
       TERRITORYID  TERRITORY_ID,
