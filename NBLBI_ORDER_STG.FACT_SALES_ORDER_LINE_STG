    )
    AND CURRENT_TIMESTAMP() BETWEEN 
      COALESCE(DOO_HOLD_CODES.HOLDEFFECTIVESTARTDATE, CURRENT_TIMESTAMP()) AND 
      COALESCE(DOO_HOLD_CODES.HOLDEFFECTIVEENDDATE, CURRENT_TIMESTAMP())
