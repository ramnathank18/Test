   AND W_MCAL_DAY_D_ACT_SHPMNT_DT.MCAL_CAL_ID = 'NB CORP FISCAL'
   AND W_MCAL_DAY_D_ACT_SHPMNT_DT.PERIODADJUSTMENTPERIODFLAG = 'N'

