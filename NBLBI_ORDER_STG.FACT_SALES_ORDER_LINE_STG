   AND W_MCAL_DAY_D_PROMISE_DT.MCAL_CAL_ID = 'NB CORP FISCAL'
   AND W_MCAL_DAY_D_PROMISE_DT.PERIODADJUSTMENTPERIODFLAG = 'N'
   
