    ON  W_MCAL_DAY_D_PROMISE_DT.CAL_WEEK_WID=DIM_MCAL_PLNG_WK_D_PROMISE.WEEK_ORIGINAL_WID
      LEFT OUTER JOIN  NBLBI_CAL_COMMON.DIM_MCAL_PLANNING_WEEK DIM_MCAL_PLNG_WK_D_ACT_SHP  
    ON  W_MCAL_DAY_D_ACT_SHPMNT_DT.CAL_WEEK_WID=DIM_MCAL_PLNG_WK_D_ACT_SHP.WEEK_ORIGINAL_WID
      LEFT OUTER JOIN  NBLBI_CAL_COMMON.DIM_MCAL_PLANNING_WEEK DIM_MCAL_PLNG_WK_D_CRTD  
    ON  W_MCAL_DAY_D_CREATED_ON_DT.CAL_WEEK_WID=DIM_MCAL_PLNG_WK_D_CRTD.WEEK_ORIGINAL_WID
	-- 🔹 Standard UOM Conversion
	LEFT JOIN NBLBI_FUSION_ITEM_COMMON.RCS_ITEM_UOM_CONVERSIONS UOMC
