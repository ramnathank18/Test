   AND W_MCAL_DAY_D_ORDERED_DT.MCAL_CAL_ID = 'NB CORP FISCAL'
   AND W_MCAL_DAY_D_ORDERED_DT.PERIODADJUSTMENTPERIODFLAG = 'N'

-- Request Date
LEFT OUTER JOIN NBLBI_CAL_COMMON.DIM_MCAL_DAY W_MCAL_DAY_D_REQ_DT  
    ON date_format( SOL.X_REQUEST_DATE,'yyyy-MM-dd')=  date_format( W_MCAL_DAY_D_REQ_DT.MCAL_DAY_DT,'yyyy-MM-dd')
   AND W_MCAL_DAY_D_REQ_DT.MCAL_CAL_ID = 'NB CORP FISCAL'
   AND W_MCAL_DAY_D_REQ_DT.PERIODADJUSTMENTPERIODFLAG = 'N'

