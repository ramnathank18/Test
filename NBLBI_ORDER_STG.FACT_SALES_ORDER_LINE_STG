       -- SRC_EFF_TO_DT
    FROM NBLBI_PARTY_COMMON.DIM_CUSTOMER_SITES W_CUST_LOC_USE_PS
    WHERE SITEUSECODE = 'SHIP_TO'
) LKP_W_CUST_LOC_USE_PS_SHP_TO
    ON CAST(BASE.SHIP_TO_ORG_ID1 as string) = LKP_W_CUST_LOC_USE_PS_SHP_TO.SITE_USE_ID
