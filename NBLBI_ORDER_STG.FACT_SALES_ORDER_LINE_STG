	LEFT JOIN  NBLBI_PARTY_COMMON.DIM_PARTY_CONTACT DIM_PARTY_CONTACT_3 
    ON SOL.KEY_CUSTOMER_CNTCT_ID  = DIM_PARTY_CONTACT_3.CONTACT_PARTY_ID 
	
    
 LEFT OUTER JOIN  NBLBI_ONT.DIM_ORDER_SOURCE DIM_ORDER_SOURCE_X_OLA  
    ON  SOL.X_OLA_ORDER_SOURCE_ID=DIM_ORDER_SOURCE_X_OLA.ORDER_SOURCE 
	
	LEFT OUTER JOIN  NBLBI_ONT.DIM_ORDER_SOURCE DIM_ORDER_SOURCE  
   ON  SOL.ORDER_SOURCE_ID =DIM_ORDER_SOURCE.ORDER_SOURCE
	
 LEFT OUTER JOIN  NBLBI_PARTY_COMMON.DIM_CUSTOMER_ACCOUNTS DIM_CUSTOMER_ACCOUNT_END_CUST 
    ON  SUBSTRING(W_INV_PRODUCT_D_END_CUST.X_END_CUSTOMER, 6, LENGTH(W_INV_PRODUCT_D_END_CUST.X_END_CUSTOMER))
	=DIM_CUSTOMER_ACCOUNT_END_CUST.ACCOUNT_NUMBER
	
	LEFT OUTER JOIN  NBLBI_PARTY_COMMON.DIM_CUST_SITE_USE DIM_CUST_SITE_USE_D_STATE_CODE  
    ON  CONCAT_WS('-',1,nvl(SOL.X_SHIP_TO_ORG_ID,0))=DIM_CUST_SITE_USE_D_STATE_CODE.PK_CUST_SITE_USE_ID
	AND DIM_CUST_SITE_USE_D_STATE_CODE.SITE_USE_CODE='SHIP_TO'
	
/*	LEFT OUTER JOIN  NBLBI_ONT.DIM_OM_REASON DIM_OM_REASON   
    ON  SOL.RETURN_REASON_CODE=DIM_OM_REASON.LOOKUP_CODE */
--changed on 20-2-2026 for Devops #143501
