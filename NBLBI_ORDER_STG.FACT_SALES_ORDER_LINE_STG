LEFT OUTER JOIN NBLBI_PARTY_COMMON.DIM_CUST_SITE_USE WC_CUST_SITE_USE_D1_SHIP_TO
  ON SOL.KEY_SHIP_TO_ORG_ID = WC_CUST_SITE_USE_D1_SHIP_TO.PK_CUST_SITE_USE_ID
  AND WC_CUST_SITE_USE_D1_SHIP_TO.SITE_USE_CODE = 'SHIP_TO'

LEFT OUTER JOIN NBLBI_PARTY_COMMON.DIM_CUST_SITE_USE WC_CUST_SITE_USE_D1_BILL_TO
