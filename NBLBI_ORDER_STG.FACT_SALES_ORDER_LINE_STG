  LEFT OUTER JOIN NBLBI_PARTY_COMMON.DIM_CUSTOMER_LOC DIM_CUSTOMER_LOC_3
  ON SOL.KEY_CUSTOMER_SHIP_TO_LOC_ID = DIM_CUSTOMER_LOC_3.PK_CUST_LOC_ID
  
