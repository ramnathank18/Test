WITH RECEIPT_DETAILS AS (
SELECT 
    HEADER_ID,
    LINE_ID,
    	DESTINATION_ORGANIZATION_ID,
	NEED_BY_DATE,
	CREATION_DATE,
	LAST_UPDATE_DATE,
    TRANSFER_RECEIPT_DATE,
    TRANSFER_RECEIPT_NUMBER,
    PO_LAST_UPDATE_DATE
FROM (
    SELECT 
           TOH.TOHEADERPEOHEADERID AS HEADER_ID,
           TOL.TOLINEPEOLINEID AS LINE_ID,
           TOL.TOLINEPEODESTINATIONORGANIZATIONID AS DESTINATION_ORGANIZATION_ID,
		   TOL.TOLINEPEONEEDBYDATE AS NEED_BY_DATE,
		   TOL.TOLINEPEOCREATIONDATE CREATION_DATE,
		   TOL.TOLINEPEOLASTUPDATEDATE LAST_UPDATE_DATE,
           DATE_FORMAT(TO_TIMESTAMP(RT.RCVNGRCPTTRNSCTNEXTRCTPEOTRANSACTIONDATE), 'dd-MMM-yyyy HH:mm:ss') AS TRANSFER_RECEIPT_DATE,
           RSH.RECEIPTNUM AS TRANSFER_RECEIPT_NUMBER,
           LEAST(
                TOH.TOHEADERPEOLASTUPDATEDATE,
                TOL.TOLINEPEOLASTUPDATEDATE,
                RSH.LASTUPDATEDATE,
                RT.RCVNGRCPTTRNSCTNEXTRCTPEOLASTUPDATEDATE,
                RSL.LASTUPDATEDATE
           ) AS PO_LAST_UPDATE_DATE,
		    ROW_NUMBER() OVER (PARTITION BY TOH.TOHEADERPEOHEADERID, TOL.TOLINEPEOLINEID ORDER BY RT.RCVNGRCPTTRNSCTNEXTRCTPEOTRANSACTIONDATE) AS RN
    FROM NBLBI_FUSION_INV.INV_TRANSFER_ORDER_HEADERS TOH
    INNER JOIN NBLBI_FUSION_INV.INV_TRANSFER_ORDER_LINES TOL
        ON TOH.TOHEADERPEOHEADERID = TOL.TOLINEPEOHEADERID
    LEFT OUTER JOIN NBLBI_FUSION_PO.RCV_SHIPMENT_LINES RSL 
        ON TOL.TOLINEPEOLINEID = RSL.TRANSFERORDERLINEID
    LEFT OUTER JOIN NBLBI_FUSION_PO.RCV_SHIPMENT_HEADERS RSH
        ON RSH.SHIPMENTHEADERID = RSL.SHIPMENTHEADERID
		LEFT OUTER JOIN NBLBI_FUSION_PO.RCV_TRANSACTIONS RT
        ON RSL.SHIPMENTHEADERID = RT.RCVNGRCPTTRNSCTNEXTRCTPEOSHIPMENTHEADERID
    AND  RT.RCVNGRCPTTRNSCTNEXTRCTPEOTRANSACTIONTYPE = 'DELIVER' 
    )
WHERE RN = 1
),
INVOP as (
  SELECT ORGANIZATIONID
  FROM NBLBI_FUSION_ITEM_COMMON.INV_ORG_PARAMETERS
  WHERE ORGANIZATIONCODE = 'MAS'
),

